# Application
APP_ENV=development
APP_PORT=8080
APP_NAME=gaiol
APP_VERSION=1.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=gaiol
DB_PASSWORD=gaiol
DB_NAME=gaiol
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AI Model Providers
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro

# Security
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=24h

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
